---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url }}"
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
          ><i class="fa-solid fa-file-pdf"></i
        ></a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {% if page.cv_pdf %}
      <div style="width:100%; height:85vh;">
        <iframe
          src="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url }}"
          width="100%"
          height="100%"
          style="border:none;"
        >
        </iframe>
      </div>
      <p style="margin-top:1rem; text-align:center;">
        <a
          href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url }}"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open PDF in new tab
        </a>
      </p>
    {% else %}
      <p style="color: var(--global-text-color-light);">No CV available.</p>
    {% endif %}
  </article>
</div>
